{
  "name": "open-yukkuri-editor",
  "version": "0.1.0",
  "description": "Open Yukkuri Editor - ゆっくりMovieMaker4互換 動画編集デスクトップアプリ",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "icon": "node scripts/generate-icon.mjs",
    "package": "npm run icon && npm run build && electron-builder --win",
    "package:portable": "npm run icon && npm run build && electron-builder --win --config.win.target=portable --config.win.signAndEditExecutable=false",
    "package:nsis": "npm run icon && npm run build && electron-builder --win --config.win.target=nsis --config.win.signAndEditExecutable=false"
  },
  "build": {
    "appId": "com.open-yukkuri.editor",
    "productName": "Open Yukkuri Editor",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "buildResources/icon.png",
      "artifactName": "${name}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Open Yukkuri Editor",
      "language": "1041",
      "unicode": true,
      "installerIcon": "buildResources/icon.png",
      "uninstallerIcon": "buildResources/icon.png"
    },
    "portable": {
      "artifactName": "${name}-${version}-portable-${arch}.exe",
      "requestExecutionLevel": "user"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.33.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
